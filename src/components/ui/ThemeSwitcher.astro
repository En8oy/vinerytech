---
/**
 * ThemeSwitcher Component
 * Permite cambiar entre los diferentes temas de color del sitio.
 * Los temas se aplican mediante el atributo data-theme en el elemento html.
 */

interface Theme {
  id: string;
  name: string;
  color: string;
}

const themes: Theme[] = [
  { id: 'gsap', name: 'Neón', color: '#0ae448' },
  { id: 'cyber', name: 'Cyber', color: '#00d4ff' },
  { id: 'sunset', name: 'Sunset', color: '#fb923c' },
  { id: 'matrix', name: 'Matrix', color: '#00ff41' },
  { id: 'aurora', name: 'Aurora', color: '#86efac' },
];

interface Props {
  class?: string;
  showLabels?: boolean;
  position?: 'inline' | 'fixed';
}

const { class: className = '', showLabels = false, position = 'inline' } = Astro.props;
---

<div
  class:list={['theme-switcher', position === 'fixed' && 'theme-switcher--fixed', className]}
  role="group"
  aria-label="Selector de tema de colores"
>
  {
    themes.map((theme) => (
      <button
        data-theme-btn={theme.id}
        class="theme-btn"
        style={`--btn-color: ${theme.color}`}
        aria-label={`Cambiar a tema ${theme.name}`}
        title={theme.name}
      >
        <span class="theme-dot" />
        {showLabels && <span class="theme-label">{theme.name}</span>}
      </button>
    ))
  }
</div>

<script>
  function initThemeSwitcher() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-btn]');
    const saved = localStorage.getItem('vinery-theme') || 'gsap';

    // Apply saved theme
    document.documentElement.setAttribute('data-theme', saved);

    // Update active state
    updateActiveButton(saved);

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const theme = btn.dataset.themeBtn;
        if (!theme) return;

        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('vinery-theme', theme);
        updateActiveButton(theme);

        // Dispatch custom event for other components
        window.dispatchEvent(new CustomEvent('themechange', { detail: { theme } }));
      });
    });
  }

  function updateActiveButton(activeTheme: string) {
    document.querySelectorAll<HTMLButtonElement>('[data-theme-btn]').forEach((btn) => {
      const isActive = btn.dataset.themeBtn === activeTheme;
      btn.classList.toggle('active', isActive);
      btn.setAttribute('aria-pressed', String(isActive));
    });
  }

  // Initialize on page load (works with View Transitions)
  document.addEventListener('astro:page-load', initThemeSwitcher);

  // Also run immediately for initial load without View Transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initThemeSwitcher);
  } else {
    initThemeSwitcher();
  }
</script>

<style>
  .theme-switcher {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .theme-switcher--fixed {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 50;
    padding: 0.75rem;
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: 9999px;
    box-shadow: var(--glass-shadow);
  }

  .theme-btn {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 1.75rem;
    height: 1.75rem;
    padding: 0;
    border-radius: 50%;
    border: 2px solid var(--btn-color);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .theme-btn:hover {
    transform: scale(1.15);
    box-shadow: 0 0 20px color-mix(in srgb, var(--btn-color) 50%, transparent);
  }

  .theme-btn:focus-visible {
    outline: 2px solid var(--btn-color);
    outline-offset: 2px;
  }

  .theme-btn.active {
    background: var(--btn-color);
    box-shadow: 0 0 15px color-mix(in srgb, var(--btn-color) 60%, transparent);
  }

  .theme-dot {
    display: block;
    width: 0.625rem;
    height: 0.625rem;
    margin: auto;
    border-radius: 50%;
    background: var(--btn-color);
    transition: transform 0.3s ease;
  }

  .theme-btn.active .theme-dot {
    background: var(--theme-surface);
    transform: scale(0.8);
  }

  .theme-label {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-bottom: 0.5rem;
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--aw-color-text-default);
    background: var(--theme-surface-elevated);
    border: 1px solid var(--glass-border);
    border-radius: 0.375rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .theme-btn:hover .theme-label {
    opacity: 1;
  }

  /* Touch devices */
  @media (hover: none) {
    .theme-btn:active {
      transform: scale(0.95);
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .theme-btn {
      transition: none;
    }

    .theme-dot {
      transition: none;
    }
  }
</style>
