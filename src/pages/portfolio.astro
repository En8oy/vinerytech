---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Portfolio - Casos de Éxito | VineryDev',
  description:
    'Descubre cómo VineryDev ha desarrollado sistemas web, automatizaciones e infraestructura para 45+ empresas. Casos reales con métricas verificables y ROI comprobado.',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Casos de Éxito Reales"
    title="150+ Proyectos Exitosos, Resultados Medibles"
    subtitle="Plataformas SaaS escalables, e-commerce que venden millones, automatizaciones que ahorran cientos de horas, infraestructura cloud con 99.9% uptime. Cada proyecto con métricas reales y tecnologías verificables."
  />

  <!-- Stats Widget ****************** -->

  <Stats
    title="Resultados en Números"
    stats={[
      { title: 'Proyectos Completados', amount: '150+' },
      { title: 'Clientes Satisfechos', amount: '45+' },
      { title: 'Horas Automatizadas', amount: '100K+' },
      { title: 'ROI Promedio', amount: '320%' },
      { title: 'Uptime Promedio', amount: '99.9%' },
      { title: 'Código Deployado', amount: '500K+ líneas' },
    ]}
  />

  <!-- Featured Projects Section ****************** -->

  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-semibold mb-4">Proyectos Destacados</h2>
      <p class="text-xl text-gray-600 dark:text-gray-400">Casos reales con impacto medible y tecnología de punta</p>
    </div>

    <!-- Project 1: E-learning SaaS -->
    <div class="mb-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div
            class="inline-block bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 px-3 py-1 rounded-full text-sm font-semibold mb-4"
          >
            E-LEARNING • PLATAFORMA SaaS
          </div>
          <h3 class="text-3xl font-semibold mb-4">LearnHub - Plataforma E-learning</h3>
          <p class="text-lg text-gray-600 dark:text-gray-400 mb-6">
            Plataforma completa de cursos online con suscripciones, videos, quizzes interactivos, certificados PDF
            dinámicos y analytics para instructores. Sistema de roles completo y chat en tiempo real.
          </p>

          <div class="grid md:grid-cols-2 gap-4 mb-6">
            <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4">
              <h4 class="font-semibold mb-2">🎯 Desafío</h4>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                Startup EdTech necesitaba plataforma completa con budget ajustado y timeline de 4 meses
              </p>
            </div>
            <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4">
              <h4 class="font-semibold mb-2">💰 Resultados</h4>
              <p class="text-sm text-green-700 dark:text-green-400">
                $45K MRR al mes 6 • 500 usuarios mes 1 • 0 downtime en 6 meses
              </p>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 mb-6">
            <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded text-xs">React</span>
            <span class="bg-green-100 text-green-800 px-2 py-1 rounded text-xs">TypeScript</span>
            <span class="bg-orange-100 text-orange-800 px-2 py-1 rounded text-xs">Laravel API</span>
            <span class="bg-purple-100 text-purple-800 px-2 py-1 rounded text-xs">PostgreSQL</span>
            <span class="bg-red-100 text-red-800 px-2 py-1 rounded text-xs">AWS (EC2, RDS, S3)</span>
            <span class="bg-pink-100 text-pink-800 px-2 py-1 rounded text-xs">Stripe</span>
            <span class="bg-indigo-100 text-indigo-800 px-2 py-1 rounded text-xs">Socket.io</span>
          </div>

          <div class="text-sm text-gray-600 dark:text-gray-400">
            <p><strong>Cliente:</strong> LearnHub (Startup EdTech, USA)</p>
            <p><strong>Duración:</strong> 4 meses • <strong>Inversión:</strong> $35,000</p>
          </div>
        </div>

        <div
          class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-800/20 rounded-2xl p-8"
        >
          <div class="mb-6">
            <h4 class="font-semibold mb-4 text-center">Métricas de Impacto</h4>
            <div class="grid grid-cols-2 gap-4">
              <div class="text-center">
                <div class="text-2xl font-semibold text-blue-600">500</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">Usuarios primer mes</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-semibold text-green-600">$45K</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">MRR al mes 6</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-semibold text-purple-600">99.9%</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">Uptime</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-semibold text-orange-600">&lt; 2seg</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">Carga de página</div>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-gray-900 rounded-lg p-4">
            <h5 class="font-semibold mb-2">💬 Testimonio del Cliente</h5>
            <p class="text-sm italic text-gray-600 dark:text-gray-400">
              "VineryDev no solo entregó código, entregó un producto que cambió nuestro negocio. La arquitectura que
              diseñaron sigue soportando nuestro crecimiento."
            </p>
            <p class="text-xs text-gray-500 mt-2">- Sarah Chen, CEO LearnHub</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Project 2: Marketplace B2B -->
    <div class="mb-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div
          class="bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900/20 dark:to-green-800/20 rounded-2xl p-8 order-2 lg:order-1"
        >
          <div class="mb-6">
            <h4 class="font-semibold mb-4 text-center">Marketplace de Alto Volumen</h4>
            <div class="grid grid-cols-2 gap-4 mb-4">
              <div class="text-center">
                <div class="text-2xl font-semibold text-green-600">$2.3M</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">Transacciones año 1</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-semibold text-blue-600">200+</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">Proveedores activos</div>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-gray-900 rounded-lg p-4 mb-4">
            <h5 class="font-semibold mb-2">🔄 Features Implementadas</h5>
            <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
              <li>• Catálogo de 50,000+ productos</li>
              <li>• Sistema de cotizaciones B2B</li>
              <li>• Multi-vendor con comisiones automáticas</li>
              <li>• Integración con SAP (ERP cliente)</li>
              <li>• Reputación y sistema de reviews</li>
            </ul>
          </div>

          <div class="bg-white dark:bg-gray-900 rounded-lg p-4">
            <h5 class="font-semibold mb-2">📊 Impacto Operativo</h5>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              Reducción 70% en tiempo de procesamiento de órdenes. 85% de proveedores activos mensualmente. $345K
              anuales en comisiones.
            </p>
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <div
            class="inline-block bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 px-3 py-1 rounded-full text-sm font-semibold mb-4"
          >
            B2B • MARKETPLACE • ENTERPRISE
          </div>
          <h3 class="text-3xl font-semibold mb-4">Marketplace Industrial B2B</h3>
          <p class="text-lg text-gray-600 dark:text-gray-400 mb-6">
            Plataforma digital que conecta 200+ proveedores con 1,000+ compradores en el sector manufacturero. Sistema
            completo de cotizaciones, órdenes de compra y pagos integrados.
          </p>

          <div class="grid md:grid-cols-2 gap-4 mb-6">
            <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4">
              <h4 class="font-semibold mb-2">🎯 Problema</h4>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                Proceso manual de compras entre distribuidora y proveedores era lento e ineficiente
              </p>
            </div>
            <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4">
              <h4 class="font-semibold mb-2">🚀 Solución</h4>
              <p class="text-sm text-green-700 dark:text-green-400">
                Marketplace completo con integración SAP y pagos automatizados
              </p>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 mb-6">
            <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded text-xs">Vue.js</span>
            <span class="bg-green-100 text-green-800 px-2 py-1 rounded text-xs">Laravel</span>
            <span class="bg-orange-100 text-orange-800 px-2 py-1 rounded text-xs">MySQL</span>
            <span class="bg-purple-100 text-purple-800 px-2 py-1 rounded text-xs">Redis</span>
            <span class="bg-red-100 text-red-800 px-2 py-1 rounded text-xs">Laravel Horizon</span>
            <span class="bg-pink-100 text-pink-800 px-2 py-1 rounded text-xs">Stripe</span>
          </div>

          <div class="text-sm text-gray-600 dark:text-gray-400">
            <p><strong>Cliente:</strong> Empresa de distribución industrial (México)</p>
            <p><strong>Duración:</strong> 6 meses • <strong>Inversión:</strong> $45,000</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Project 3: Automatización Agencia Marketing -->
    <div class="mb-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div
            class="inline-block bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 px-3 py-1 rounded-full text-sm font-semibold mb-4"
          >
            AUTOMATIZACIÓN • INTEGRACIONES
          </div>
          <h3 class="text-3xl font-semibold mb-4">Automatización de Operaciones Agencia</h3>
          <p class="text-lg text-gray-600 dark:text-gray-400 mb-6">
            Suite completa de automatizaciones que eliminó 38 horas semanales de trabajo manual: reportes de campañas,
            facturación, lead nurturing, onboarding de clientes y gestión de redes sociales.
          </p>

          <div class="grid md:grid-cols-2 gap-4 mb-6">
            <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4">
              <h4 class="font-semibold mb-2">📞 Antes</h4>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                40 horas semanales en reportes manuales, facturación y procesos internos
              </p>
            </div>
            <div class="bg-purple-50 dark:bg-purple-900/20 rounded-lg p-4">
              <h4 class="font-semibold mb-2">🤖 Después</h4>
              <p class="text-sm text-purple-700 dark:text-purple-400">
                38 horas ahorradas • ROI 450% • De 12 a 25 clientes
              </p>
            </div>
          </div>

          <div
            class="bg-gradient-to-r from-purple-50 to-blue-50 dark:from-purple-900/20 dark:to-blue-900/20 rounded-lg p-4 mb-6"
          >
            <h4 class="font-semibold mb-2">⚙️ Automatizaciones Implementadas</h4>
            <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
              <li>• Reportes de campañas: Meta/Google Ads → PDF → Email</li>
              <li>• Facturación: Stripe webhook → Zoho Books → Cliente</li>
              <li>• Lead Nurturing: Form → GoHighLevel → Email/SMS</li>
              <li>• Onboarding: Pago → ClickUp → Slack → Email</li>
              <li>• Social Media: Buffer → Posts → Analytics → Reporte</li>
            </ul>
          </div>

          <div class="flex flex-wrap gap-2 mb-6">
            <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded text-xs">N8N</span>
            <span class="bg-green-100 text-green-800 px-2 py-1 rounded text-xs">Make</span>
            <span class="bg-orange-100 text-orange-800 px-2 py-1 rounded text-xs">GoHighLevel</span>
            <span class="bg-purple-100 text-purple-800 px-2 py-1 rounded text-xs">Zapier</span>
            <span class="bg-red-100 text-red-800 px-2 py-1 rounded text-xs">Meta Ads API</span>
          </div>

          <div class="text-sm text-gray-600 dark:text-gray-400">
            <p><strong>Cliente:</strong> Agencia de marketing digital (Colombia)</p>
            <p><strong>Duración:</strong> 6 semanas • <strong>Inversión:</strong> $8,500</p>
          </div>
        </div>

        <div
          class="bg-gradient-to-br from-purple-50 to-purple-100 dark:from-purple-900/20 dark:to-purple-800/20 rounded-2xl p-8"
        >
          <div class="mb-6">
            <h4 class="font-semibold mb-4 text-center">Métricas de Éxito</h4>
            <div class="grid grid-cols-2 gap-4">
              <div class="text-center">
                <div class="text-2xl font-semibold text-purple-600">38hrs</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">Ahorradas/semana</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-semibold text-green-600">450%</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">ROI en 4 meses</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-semibold text-blue-600">0</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">Errores facturación</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-semibold text-orange-600">25</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">Clientes (vs 12 antes)</div>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-gray-900 rounded-lg p-4">
            <h5 class="font-semibold mb-2">💬 Testimonio</h5>
            <p class="text-sm italic text-gray-600 dark:text-gray-400">
              "Las automatizaciones liberaron a mi equipo de 38 horas semanales de trabajo manual. Pudimos crecer de 12
              a 25 clientes sin contratar personal adicional."
            </p>
            <p class="text-xs text-gray-500 mt-2">- Carlos Rodríguez, Director Agencia</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Project 4: Migración Cloud Fintech -->
    <div class="mb-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div
          class="bg-gradient-to-br from-red-50 to-orange-100 dark:from-red-900/20 dark:to-orange-800/20 rounded-2xl p-8 order-2 lg:order-1"
        >
          <div class="mb-6">
            <h4 class="font-semibold mb-4 text-center">Infraestructura Enterprise</h4>
            <div class="grid grid-cols-2 gap-4 mb-4">
              <div class="text-center">
                <div class="text-2xl font-semibold text-red-600">99.97%</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">Uptime logrado</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-semibold text-blue-600">8 min</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">Deploy time (vs 4hrs)</div>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-gray-900 rounded-lg p-4 mb-4">
            <h5 class="font-semibold mb-2">🏗️ Arquitectura Implementada</h5>
            <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
              <li>• Kubernetes en AWS EKS</li>
              <li>• RDS PostgreSQL Multi-AZ</li>
              <li>• ElastiCache Redis Cluster</li>
              <li>• S3 + CloudFront CDN</li>
              <li>• Load Balancer + Auto Scaling</li>
            </ul>
          </div>

          <div class="bg-white dark:bg-gray-900 rounded-lg p-4">
            <h5 class="font-semibold mb-2">🔒 Seguridad & Compliance</h5>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              WAF implementado, Secrets Manager, encriptación end-to-end. Certificación PCI-DSS Level 1 obtenida.
            </p>
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <div
            class="inline-block bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400 px-3 py-1 rounded-full text-sm font-semibold mb-4"
          >
            CLOUD MIGRATION • DEVOPS • KUBERNETES
          </div>
          <h3 class="text-3xl font-semibold mb-4">Migración Cloud + DevOps Fintech</h3>
          <p class="text-lg text-gray-600 dark:text-gray-400 mb-6">
            Migración completa de aplicación legacy de servidores propios a AWS con alta disponibilidad, auto-scaling y
            cumplimiento PCI-DSS. Infraestructura moderna y escalable.
          </p>

          <div class="grid md:grid-cols-2 gap-4 mb-6">
            <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4">
              <h4 class="font-semibold mb-2">🎯 Problema</h4>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                Legacy en servidores propios, 98.2% uptime, deploys de 4 horas, sin compliance
              </p>
            </div>
            <div class="bg-red-50 dark:bg-red-900/20 rounded-lg p-4">
              <h4 class="font-semibold mb-2">🚀 Resultado</h4>
              <p class="text-sm text-red-700 dark:text-red-400">
                99.97% uptime • Deploy 8 min • PCI-DSS Level 1 • -35% costos
              </p>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 mb-6">
            <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded text-xs">AWS EKS</span>
            <span class="bg-green-100 text-green-800 px-2 py-1 rounded text-xs">Kubernetes</span>
            <span class="bg-orange-100 text-orange-800 px-2 py-1 rounded text-xs">Docker</span>
            <span class="bg-purple-100 text-purple-800 px-2 py-1 rounded text-xs">Terraform</span>
            <span class="bg-red-100 text-red-800 px-2 py-1 rounded text-xs">GitHub Actions</span>
            <span class="bg-pink-100 text-pink-800 px-2 py-1 rounded text-xs">Prometheus</span>
          </div>

          <div class="text-sm text-gray-600 dark:text-gray-400">
            <p><strong>Cliente:</strong> Fintech (Argentina)</p>
            <p><strong>Duración:</strong> 3 meses • <strong>Inversión:</strong> $38,000</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Project 5: E-commerce Moda -->
    <div class="mb-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div
            class="inline-block bg-pink-100 dark:bg-pink-900/30 text-pink-600 dark:text-pink-400 px-3 py-1 rounded-full text-sm font-semibold mb-4"
          >
            E-COMMERCE • MARKETING DIGITAL • DISEÑO
          </div>
          <h3 class="text-3xl font-semibold mb-4">E-commerce de Moda - Lanzamiento Completo</h3>
          <p class="text-lg text-gray-600 dark:text-gray-400 mb-6">
            Marca nueva sin presencia digital: diseño de identidad completa, e-commerce personalizado en Shopify,
            fotografía de 120 productos, estrategia digital y campañas de conversión en Meta Ads y Google Shopping.
          </p>

          <div class="grid md:grid-cols-2 gap-4 mb-6">
            <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4">
              <h4 class="font-semibold mb-2">🎯 Desafío</h4>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                Lanzar marca nueva desde cero: identidad, e-commerce, fotografía y marketing
              </p>
            </div>
            <div class="bg-pink-50 dark:bg-pink-900/20 rounded-lg p-4">
              <h4 class="font-semibold mb-2">💰 Resultados</h4>
              <p class="text-sm text-pink-700 dark:text-pink-400">
                $78K ventas Q1 • 15K seguidores • 4.2 ROAS • 18% conversion
              </p>
            </div>
          </div>

          <div
            class="bg-gradient-to-r from-pink-50 to-purple-50 dark:from-pink-900/20 dark:to-purple-900/20 rounded-lg p-4 mb-6"
          >
            <h4 class="font-semibold mb-2">🎨 Servicios Entregados</h4>
            <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
              <li>• Diseño de logo y manual de marca completo</li>
              <li>• Sesión fotográfica profesional 120 productos</li>
              <li>• E-commerce Shopify personalizado</li>
              <li>• Integración Stripe + MercadoPago</li>
              <li>• Setup Facebook/Instagram Shopping</li>
              <li>• Campañas Meta Ads + Google Shopping</li>
              <li>• Email flows con Klaviyo</li>
            </ul>
          </div>

          <div class="flex flex-wrap gap-2 mb-6">
            <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded text-xs">Shopify</span>
            <span class="bg-green-100 text-green-800 px-2 py-1 rounded text-xs">Liquid</span>
            <span class="bg-orange-100 text-orange-800 px-2 py-1 rounded text-xs">Meta Ads</span>
            <span class="bg-purple-100 text-purple-800 px-2 py-1 rounded text-xs">Google Ads</span>
            <span class="bg-red-100 text-red-800 px-2 py-1 rounded text-xs">Klaviyo</span>
            <span class="bg-pink-100 text-pink-800 px-2 py-1 rounded text-xs">Photoshop</span>
          </div>

          <div class="text-sm text-gray-600 dark:text-gray-400">
            <p><strong>Cliente:</strong> E-commerce de moda (Perú)</p>
            <p><strong>Duración:</strong> 8 semanas • <strong>Inversión:</strong> $18,000</p>
          </div>
        </div>

        <div
          class="bg-gradient-to-br from-pink-50 to-purple-100 dark:from-pink-900/20 dark:to-purple-800/20 rounded-2xl p-8"
        >
          <div class="mb-6">
            <h4 class="font-semibold mb-4 text-center">Resultados de Marketing</h4>
            <div class="grid grid-cols-2 gap-4">
              <div class="text-center">
                <div class="text-2xl font-semibold text-pink-600">$78K</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">Ventas primer trimestre</div>
